# Backend host for local dev.
# Leave API_HOST unset to auto-pick: iOS sim -> localhost, Android emulator -> 10.0.2.2.
# For a PHYSICAL device, uncomment and set your Mac's LAN IP (changes per network):
# API_HOST=192.168.1.50
API_SCHEME=http
API_PORT=5001

